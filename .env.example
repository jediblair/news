# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=changeme_strong_password

# ─── Session ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=changeme_generate_with_openssl_rand_hex_32

# ─── Claude API (optional) ────────────────────────────────────
CLAUDE_API_KEY=

# ─── Ollama (set to empty string to disable local LLM) ────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ─── Web App ──────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost
NODE_ENV=production

# ─── Ingestion ────────────────────────────────────────────────
# Max article age in days (articles older than this are skipped)
MAX_ARTICLE_AGE_DAYS=2
# Request timeout in ms
CRAWL_TIMEOUT_MS=30000
# Max response size in bytes (10MB)
CRAWL_MAX_BYTES=10485760
